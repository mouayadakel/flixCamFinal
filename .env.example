# Database
DATABASE_URL="postgresql://user:password@localhost:5432/flixcam_rent?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
# AUTH_SECRET="" # Alias for NEXTAUTH_SECRET (used by some auth libs)
# NEXTAUTH_URL must match the app URL including port. If using "next dev -p 3001", use:
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Sign in with Google) — from Google Cloud Console OAuth 2.0 Client (Web application)
# Add authorized redirect URI: https://yourdomain.com/api/auth/callback/google (and http://localhost:3000/... for local)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cron jobs (e.g. nightly backfill) — required for /api/cron/*
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Blog preview mode (draft posts with ?preview=true&token=xxx)
BLOG_PREVIEW_TOKEN=""
# Optional: separate secret for blog revalidation webhook (falls back to CRON_SECRET)
# REVALIDATE_BLOG_SECRET=""

# Tap Payments
TAP_API_KEY=your-tap-key
# TAP_API_URL="https://api.tap.company/v2" # Optional override
TAP_SECRET_KEY="sk_test_..."
TAP_PUBLIC_KEY="pk_test_..."
TAP_WEBHOOK_SECRET="whsec_..."

# Email Configuration (Resend - preferred for transactional)
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@flixcam.rent"
RESEND_FROM_NAME="FlixCam.rent"

# Email Configuration (SMTP fallback)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@flixcam.rent"
SMTP_FROM_NAME="FlixCam.rent"

# Email Configuration (Gmail OAuth - Alternative)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

# Email Configuration (Hotmail/Outlook - Alternative)
HOTMAIL_CLIENT_ID=""
HOTMAIL_CLIENT_SECRET=""
HOTMAIL_REFRESH_TOKEN=""

# WhatsApp Cloud API (access token used for Graph API authentication)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
# ENABLE_WHATSAPP="false"  # Set to "true" to send WhatsApp messages (see also Messaging Center in CMS)

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
# ENABLE_SMS="false"  # Set to "true" to send SMS (see also Messaging Center in CMS)

# Analytics & Tracking
GTM_CONTAINER_ID="GTM-XXXXXXX"
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
META_PIXEL_ID=""

# OpenAI (Phase 2 - AI Features)
OPENAI_API_KEY=""

# OpenAI Embeddings (for recommendAlternatives similarity)
# Default: text-embedding-ada-002
OPENAI_EMBEDDINGS_MODEL="text-embedding-ada-002"

# Google Gemini (Phase 2 - AI Features - Alternative)
GEMINI_API_KEY=""
# Alternative env name for Gemini (some SDKs use this)
GOOGLE_GENERATIVE_AI_API_KEY=""

# AI Provider Selection (for bulk import autofill, AI preview, equipment autofill)
# Options: "openai" or "gemini" — set the key for your chosen provider above
AI_PROVIDER="gemini"

# AI pricing seasonality factor (optional; default 1.0)
# AI_SEASONALITY_FACTOR="1.0"

# Pexels (image sourcing pipeline - free API key from pexels.com)
PEXELS_API_KEY=""

# Unsplash (image sourcing pipeline - free tier: 50 req/hr)
UNSPLASH_ACCESS_KEY=""

# Google Custom Search Images (image sourcing - free tier: 100 queries/day)
GOOGLE_CUSTOM_SEARCH_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""

# Pricing multipliers (optional; defaults: weekly 4, monthly 12)
# PRICING_WEEKLY_FACTOR="4"
# PRICING_MONTHLY_FACTOR="12"

# AI model override (default: gpt-4o-mini)
# AI_MODEL="gpt-4o-mini"

# Contact & Social (public)
# NEXT_PUBLIC_WHATSAPP_NUMBER="966500000000"
# NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/yourhandle"
# NEXT_PUBLIC_TIKTOK_URL="https://tiktok.com/@yourhandle"
# NEXT_PUBLIC_LINKEDIN_URL="https://linkedin.com/company/yourpage"

# Backfill worker: concurrency (default 10) and delay between batches in ms (default 500)
BACKFILL_CONCURRENCY="10"
BACKFILL_RATE_LIMIT_MS="500"

# AI cost guardrails (optional; also configurable in Admin > Settings > AI)
# AI_DAILY_BUDGET_USD="50"
# AI_MONTHLY_BUDGET_USD="500"

# Redis (for rate limiting, caching, and BullMQ job queues)
REDIS_URL="redis://localhost:6379"

# RBAC - Use new DB-driven permission system (Phase 11 rollout)
# Set to "true" to enable new RBAC with roles/permissions from database
# Default: false (uses legacy enum-based User.role)
USE_NEW_RBAC="false"

# Cloudinary (for image processing in bulk imports)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# File Storage (Phase 1: Local, Phase 2: Cloud)
STORAGE_TYPE="local"
# For cloud storage (Phase 2):
# STORAGE_TYPE="s3"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""

# ZATCA
ZATCA_API_URL=https://api.zatca.gov.sa
# ZATCA_COMPANY_NAME="" # Optional override for seller name
ZATCA_API_KEY=your-zatca-key
ZATCA_COMPANY_VAT=300012345600003
ZATCA_COMPANY_CR=1010123456

# Application
APP_ENV="development"
# NEXT_PUBLIC_AI_WIDGET_ENABLED="false" # Enable AI floating widget in admin
APP_URL="http://localhost:3000"
APP_NAME="FlixCam.rent"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags (can be overridden in database)
ENABLE_BOOKING_CHECKOUT="true"
# ENABLE_TEST_AUTH="" # Allow test auth endpoints in production (dev only)
ENABLE_PAYMENTS="true"
ENABLE_WHATSAPP="false"
ENABLE_AI_RECOMMENDATIONS="false"

# Rate Limiting
RATE_LIMIT_API_REQUESTS_PER_HOUR="100"
RATE_LIMIT_AUTH_ATTEMPTS_PER_15MIN="10"

# Upstash Redis (optional - for rate limiting and caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry (Phase 0.4 - Error tracking)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Security
ALLOWED_ORIGINS="http://localhost:3000,https://flixcam.rent"
# ENCRYPTION_KEY="" # Required for integration config encryption (32 bytes hex)

# Logging
LOG_LEVEL="info"
ENABLE_AUDIT_LOGGING="true"

# Web Research (Phase 7 - Live Specs Crawler)
# Google Custom Search API for finding product pages
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
# Scraping proxy service (optional - for bypassing bot detection)
# Supported: "direct" (no proxy), "scrapingbee", "brightdata"
SCRAPING_SERVICE="direct"
SCRAPING_API_KEY=""
# Rate limiting between scrape requests (ms) — mimics human behavior
RESEARCH_RATE_LIMIT_DELAY="2000"

# Blog reactions / views anonymous salt (used for fingerprinting without PII)
REACTIONS_SALT=""
VIEWS_SALT=""

# Public contact info (displayed on site footer / header)
NEXT_PUBLIC_CONTACT_EMAIL=""
NEXT_PUBLIC_CONTACT_PHONE=""

# Google Analytics (client-side, alternative to GTM_CONTAINER_ID)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# Encryption key for API key storage in database (32 bytes hex)
ENCRYPTION_KEY=""
