// ──────────────────────────────────────────────────────────────────
// AI Smart Import: Feedback Loop & Column Mapping Memory
// ──────────────────────────────────────────────────────────────────

model AiFeedback {
  id              String   @id @default(cuid())
  draftId         String?
  contentType     String
  fieldName       String
  action          String
  rejectionReason String?
  originalValue   String?  @db.Text
  finalValue      String?  @db.Text
  provider        String?
  promptHash      String?
  categoryId      String?
  createdAt       DateTime @default(now())

  @@index([contentType])
  @@index([action])
  @@index([categoryId])
  @@index([provider])
  @@index([createdAt])
}

model ColumnMappingHistory {
  id           String   @id @default(cuid())
  sourceHeader String
  mappedField  String
  frequency    Int      @default(1)
  lastUsedAt   DateTime @default(now())
  createdBy    String?

  @@unique([sourceHeader, mappedField])
  @@index([sourceHeader])
  @@index([frequency])
}
