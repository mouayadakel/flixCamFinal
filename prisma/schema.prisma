generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String               @id @default(cuid())
  status              ProductStatus        @default(DRAFT)
  productType         ProductType          @default(RENTAL)
  sku                 String?              @unique
  brandId             String
  categoryId          String
  subCategoryId       String?
  priceDaily          Decimal              @db.Decimal(10, 2)
  priceWeekly         Decimal?             @db.Decimal(10, 2)
  priceMonthly        Decimal?             @db.Decimal(10, 2)
  depositAmount       Decimal?             @db.Decimal(10, 2)
  bufferTime          Int                  @default(0)
  boxContents         String?
  featuredImage       String
  galleryImages       Json?
  videoUrl            String?
  relatedProducts     Json?
  tags                String?
  createdAt           DateTime             @default(now())
  createdBy           String?
  updatedAt           DateTime             @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  quantity            Int?
  contentQualityScore Int?
  contentScore        Int? // 0-100 quality score, cached (plan v2.0)
  contentScoreAt      DateTime? // when score was last calculated
  lastAiRunAt         DateTime?
  aiRunCount          Int                  @default(0)
  needsAiReview       Boolean              @default(false) // flagged when AI fails
  aiReviewReason      String? // why it needs review
  aiContentFlags      Json? // { fields[], lastRun, provider, costs }
  photoStatus         String?              @default("unknown") // unknown | sufficient | needs_sourcing | reviewing
  inventoryItems      InventoryItem[]
  brand               Brand                @relation(fields: [brandId], references: [id])
  category            Category             @relation("ProductCategory", fields: [categoryId], references: [id])
  subCategory         Category?            @relation("ProductSubCategory", fields: [subCategoryId], references: [id])
  translations        ProductTranslation[]
  productImages       ProductImage[] // per-image tracking for AI workflow
  equipment           Equipment? // optional 1:1 sync to Equipment (import/AI flow)
  aiContentDrafts     AiContentDraft[] // pending AI suggestions (preview workflow)

  @@index([status])
  @@index([brandId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([deletedAt])
}

enum ImageSource {
  UPLOAD
  BRAND_ASSET
  AI_GENERATED
  STOCK_PHOTO
  WEB_SCRAPED
}

model ProductImage {
  id            String      @id @default(cuid())
  productId     String
  url           String
  imageSource   ImageSource @default(UPLOAD)
  pendingReview Boolean     @default(false)
  qualityScore  Float? // 0-1 from vision model check
  reviewedAt    DateTime?
  reviewedBy    String?
  isDeleted     Boolean     @default(false)
  createdAt     DateTime    @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([pendingReview])
  @@index([imageSource])
}

model ProductTranslation {
  id               String            @id @default(cuid())
  productId        String
  locale           TranslationLocale
  name             String
  shortDescription String
  longDescription  String
  specifications   Json?
  seoTitle         String
  seoDescription   String
  seoKeywords      String
  createdAt        DateTime          @default(now())
  createdBy        String?
  updatedAt        DateTime          @updatedAt
  updatedBy        String?
  deletedAt        DateTime?
  deletedBy        String?
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
  @@index([deletedAt])
}

model InventoryItem {
  id              String              @id @default(cuid())
  parentProductId String
  serialNumber    String              @unique
  barcode         String              @unique
  itemStatus      InventoryItemStatus @default(AVAILABLE)
  location        String?
  purchaseDate    DateTime?
  purchasePrice   Decimal?            @db.Decimal(10, 2)
  createdAt       DateTime            @default(now())
  createdBy       String?
  updatedAt       DateTime            @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  product         Product             @relation(fields: [parentProductId], references: [id], onDelete: Cascade)

  @@index([parentProductId])
  @@index([itemStatus])
  @@index([deletedAt])
}

model ImportJob {
  id                    String            @id @default(cuid())
  filename              String
  mimeType              String
  status                ImportJobStatus   @default(PENDING)
  totalRows             Int               @default(0)
  processedRows         Int               @default(0)
  successRows           Int               @default(0)
  errorRows             Int               @default(0)
  errorMessage          String?
  createdAt             DateTime          @default(now())
  createdBy             String?
  updatedAt             DateTime          @updatedAt
  updatedBy             String?
  aiProcessingStatus    String?
  imageProcessingStatus String?
  selectedRows          Json?
  selectedSheets        Json?
  aiProcessingJobs      AIProcessingJob[]
  rows                  ImportJobRow[]
}

model ImportJobRow {
  id        String          @id @default(cuid())
  jobId     String
  rowNumber Int
  status    ImportRowStatus @default(PENDING)
  error     String?
  productId String?
  payload   Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  job       ImportJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([status])
}

model AIProcessingJob {
  id             String    @id @default(cuid())
  importJobId    String
  status         String
  provider       String
  totalItems     Int
  processedItems Int       @default(0)
  failedItems    Int       @default(0)
  cost           Decimal?  @db.Decimal(10, 4)
  startedAt      DateTime?
  completedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  importJob      ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([status])
}

model AISettings {
  id                  String    @id @default(cuid())
  provider            String    @unique
  apiKey              String
  batchSize           Int       @default(50)
  timeout             Int       @default(30000)
  fallbackStrategy    String    @default("mark_for_review")
  enabled             Boolean   @default(true)
  dailyBudgetUsd      Decimal?  @db.Decimal(10, 2)
  monthlyBudgetUsd    Decimal?  @db.Decimal(10, 2)
  currentDailySpend   Decimal?  @default(0) @db.Decimal(10, 4)
  currentMonthlySpend Decimal?  @default(0) @db.Decimal(10, 4)
  spendResetDate      DateTime?
  monthlyResetDate    DateTime?
  backfillEnabled     Boolean   @default(true)
  nightlyCronEnabled  Boolean   @default(true)
  nightlyCronTime     String?   @default("02:00")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([enabled])
}

enum AiJobType {
  TEXT_BACKFILL
  PHOTO_BACKFILL
  SPEC_BACKFILL
  FULL_BACKFILL
  EMBEDDING_BACKFILL
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model AiJob {
  id          String    @id @default(cuid())
  type        AiJobType
  status      JobStatus @default(PENDING)
  triggeredBy String // "manual" | "cron" | "event" | "import"
  triggeredAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  totalItems  Int       @default(0)
  processed   Int       @default(0)
  succeeded   Int       @default(0)
  failed      Int       @default(0)
  skipped     Int       @default(0)
  costUsd     Float     @default(0)
  errorLog    Json? // [{ productId, error, timestamp }]
  metadata    Json?

  items AiJobItem[]

  @@index([status])
  @@index([type])
  @@index([triggeredAt])
}

model AiJobItem {
  id            String    @id @default(cuid())
  jobId         String
  productId     String
  itemType      String // 'text' | 'photo' | 'spec' | 'seo' | 'translation'
  status        String    @default("pending")
  error         String?
  costIncurred  Float?
  provider      String? // 'gemini' | 'openai' | 'dalle' | 'pexels'
  fieldsUpdated Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  job AiJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([productId])
  @@index([status])
}

model AiAuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String // e.g. "backfill.trigger", "image.approve", "image.reject", "settings.update"
  resourceType String? // "AiJob" | "ProductImage" | "AiSettings"
  resourceId   String?
  metadata     Json? // { jobId?, productId?, imageId?, trigger?, options? }
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AiContentDraft {
  id            String    @id @default(cuid())
  productId     String
  type          String // "text" | "spec" | "photo"
  suggestedData Json // suggested content (translations, specs, image URLs, etc.)
  status        String    @default("pending") // "pending" | "approved" | "rejected"
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model CatalogQualitySnapshot {
  id            String   @id @default(cuid())
  date          DateTime @unique // date only (midnight UTC)
  avgScore      Float // 0-100
  totalProducts Int
  gapCounts     Json // { translations: N, seo: N, photos: N, specs: N }

  @@index([date])
}

model AiDailyCost {
  id       String   @id @default(cuid())
  date     DateTime
  feature  String // "text_backfill" | "photo_generation" | "spec_inference" | "chatbot" | "embeddings"
  costUsd  Float    @default(0)
  jobCount Int      @default(0)

  @@unique([date, feature])
  @@index([date])
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  name                  String?
  phone                 String?
  role                  UserRole               @default(DATA_ENTRY)
  status                String                 @default("active")
  twoFactorEnabled      Boolean                @default(false)
  twoFactorSecret       String?
  createdAt             DateTime               @default(now())
  createdBy             String?
  updatedAt             DateTime               @updatedAt
  updatedBy             String?
  deletedAt             DateTime?
  deletedBy             String?
  segmentId             String?
  verificationStatus    VerificationStatus     @default(UNVERIFIED)
  userRoles             AssignedUserRole[]
  auditLogs             AuditLog[]
  authTokens            AuthToken[]
  createdBookings       Booking[]              @relation("CreatedBookings")
  bookings              Booking[]              @relation("CustomerBookings")
  bookingRequests       BookingRequest[]       @relation("BookingRequests")
  campaigns             Campaign[]
  cart                  Cart?
  damageClaimsReported  DamageClaim[]
  damageClaimsResolved  DamageClaim[]          @relation("ResolvedDamageClaims")
  deliveries            Delivery[]
  events                Event[]
  invoices              Invoice[]
  maintenance           Maintenance[]          @relation("MaintenanceTechnician")
  createdPricingRules   PricingRule[]
  quotes                Quote[]
  recurringSeries       RecurringSeries[]
  reviews               Review[]
  savedEquipment        SavedEquipment[]
  segment               CustomerSegment?       @relation(fields: [segmentId], references: [id])
  permissions           UserPermission[]
  vendor                Vendor?
  verificationDocuments VerificationDocument[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([segmentId])
  @@index([verificationStatus])
  @@index([deletedAt])
}

model AuthToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model SavedEquipment {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  createdAt   DateTime  @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, equipmentId])
  @@index([userId])
  @@index([equipmentId])
}

model PermissionCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  nameAr      String?
  description String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]

  @@index([sortOrder])
}

model Permission {
  id                  String               @id @default(cuid())
  name                String               @unique
  description         String?
  createdAt           DateTime             @default(now())
  createdBy           String?
  updatedAt           DateTime             @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  categoryId          String?
  descriptionAr       String?
  isSystem            Boolean              @default(false)
  sortOrder           Int                  @default(0)
  menuItemPermissions MenuItemPermission[]
  category            PermissionCategory?  @relation(fields: [categoryId], references: [id])
  rolePermissions     RolePermission[]
  userPermissions     UserPermission[]

  @@index([name])
  @@index([categoryId])
  @@index([deletedAt])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  createdAt    DateTime   @default(now())
  createdBy    String?
  updatedAt    DateTime   @updatedAt
  updatedBy    String?
  deletedAt    DateTime?
  deletedBy    String?
  permission   Permission @relation(fields: [permissionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([deletedAt])
}

model Role {
  id              String             @id @default(cuid())
  name            String             @unique
  displayName     String
  displayNameAr   String?
  description     String?
  descriptionAr   String?
  isSystem        Boolean            @default(false)
  isDefault       Boolean            @default(false)
  priority        Int                @default(0)
  color           String?
  createdAt       DateTime           @default(now())
  createdBy       String?
  updatedAt       DateTime           @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  userRoles       AssignedUserRole[]
  roleConflictsA  RoleConflict[]     @relation("RoleConflictA")
  roleConflictsB  RoleConflict[]     @relation("RoleConflictB")
  rolePermissions RolePermission[]

  @@index([name])
  @@index([isSystem])
  @@index([deletedAt])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  createdBy    String?
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model AssignedUserRole {
  id         String    @id @default(cuid())
  userId     String
  roleId     String
  isPrimary  Boolean   @default(false)
  assignedAt DateTime  @default(now())
  assignedBy String?
  expiresAt  DateTime?
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RoleConflict {
  id        String   @id @default(cuid())
  roleAId   String
  roleBId   String
  reason    String
  createdAt DateTime @default(now())
  roleA     Role     @relation("RoleConflictA", fields: [roleAId], references: [id], onDelete: Cascade)
  roleB     Role     @relation("RoleConflictB", fields: [roleBId], references: [id], onDelete: Cascade)

  @@unique([roleAId, roleBId])
  @@index([roleAId])
  @@index([roleBId])
}

model MenuItem {
  id                     String               @id @default(cuid())
  parentId               String?
  name                   String               @unique
  label                  String
  labelAr                String?
  icon                   String?
  href                   String?
  sortOrder              Int                  @default(0)
  isActive               Boolean              @default(true)
  requiresAllPermissions Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  parent                 MenuItem?            @relation("MenuItemHierarchy", fields: [parentId], references: [id])
  children               MenuItem[]           @relation("MenuItemHierarchy")
  menuItemPermissions    MenuItemPermission[]

  @@index([parentId])
  @@index([isActive])
}

model MenuItemPermission {
  id           String     @id @default(cuid())
  menuItemId   String
  permissionId String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, permissionId])
  @@index([menuItemId])
  @@index([permissionId])
}

model FeatureFlag {
  id               String           @id @default(cuid())
  name             String           @unique
  description      String?
  enabled          Boolean          @default(false)
  scope            FeatureFlagScope
  requiresApproval Boolean          @default(false)
  createdAt        DateTime         @default(now())
  createdBy        String?
  updatedAt        DateTime         @updatedAt
  updatedBy        String?
  deletedAt        DateTime?
  deletedBy        String?

  @@index([name])
  @@index([enabled])
  @@index([scope])
  @@index([deletedAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  userId       String?
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  timestamp    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([timestamp])
}

model Event {
  id           String      @id @default(cuid())
  eventName    String
  payload      Json
  userId       String?
  resourceType String?
  resourceId   String?
  status       EventStatus @default(PENDING)
  processedAt  DateTime?
  timestamp    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id])

  @@index([eventName])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([status])
  @@index([timestamp])
}

model Vendor {
  id             String         @id @default(cuid())
  userId         String         @unique
  companyName    String
  companyNameAr  String?
  slug           String         @unique
  logo           String?
  description    String?
  phone          String?
  email          String?
  commercialReg  String?
  vatNumber      String?
  bankName       String?
  iban           String?
  commissionRate Decimal        @db.Decimal(5, 2)
  status         VendorStatus   @default(PENDING)
  isNameVisible  Boolean        @default(false)
  createdAt      DateTime       @default(now())
  createdBy      String?
  updatedAt      DateTime       @updatedAt
  updatedBy      String?
  approvedAt     DateTime?
  approvedBy     String?
  deletedAt      DateTime?
  deletedBy      String?
  equipment      Equipment[]
  user           User           @relation(fields: [userId], references: [id])
  payouts        VendorPayout[]

  @@index([status])
  @@index([slug])
  @@index([userId])
  @@index([deletedAt])
}

model VendorPayout {
  id               String       @id @default(cuid())
  vendorId         String
  bookingId        String?
  periodStart      DateTime?
  periodEnd        DateTime?
  grossAmount      Decimal      @db.Decimal(10, 2)
  commissionAmount Decimal      @db.Decimal(10, 2)
  netAmount        Decimal      @db.Decimal(10, 2)
  status           PayoutStatus @default(PENDING)
  paidAt           DateTime?
  bankRef          String?
  notes            String?
  createdAt        DateTime     @default(now())
  createdBy        String?
  updatedAt        DateTime     @updatedAt
  vendor           Vendor       @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@index([bookingId])
}

model Category {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  description            String?
  parentId               String?
  createdAt              DateTime                @default(now())
  createdBy              String?
  updatedAt              DateTime                @updatedAt
  updatedBy              String?
  deletedAt              DateTime?
  deletedBy              String?
  parent                 Category?               @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children               Category[]              @relation("CategoryHierarchy")
  equipment              Equipment[]
  products               Product[]               @relation("ProductCategory")
  subProducts            Product[]               @relation("ProductSubCategory")
  shootTypeCategoryFlows ShootTypeCategoryFlow[]

  @@index([slug])
  @@index([parentId])
  @@index([deletedAt])
}

model Brand {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  logo        String?
  createdAt   DateTime    @default(now())
  createdBy   String?
  updatedAt   DateTime    @updatedAt
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?
  equipment   Equipment[]
  products    Product[]

  @@index([slug])
  @@index([deletedAt])
}

model Equipment {
  id                       String                    @id @default(cuid())
  sku                      String                    @unique
  slug                     String?                   @unique // SEO-friendly URL slug (auto-generated from model/sku)
  productId                String?                   @unique // link to Product for import/AI sync
  model                    String?
  nameEn                   String? // English name
  nameZh                   String? // Chinese name
  descriptionEn            String?                   @db.Text // English description
  descriptionZh            String?                   @db.Text // Chinese description
  categoryId               String
  brandId                  String?
  condition                EquipmentCondition        @default(GOOD)
  quantityTotal            Int                       @default(1)
  quantityAvailable        Int                       @default(1)
  dailyPrice               Decimal                   @db.Decimal(10, 2)
  weeklyPrice              Decimal?                  @db.Decimal(10, 2)
  monthlyPrice             Decimal?                  @db.Decimal(10, 2)
  featured                 Boolean                   @default(false)
  isActive                 Boolean                   @default(true)
  warehouseLocation        String?
  barcode                  String?
  specifications           Json?
  customFields             Json?
  specSource               String? // "manual" | "ai" | "import" | "migrated"
  specConfidence           Float? // 0-1 from last AI inference
  specLastInferredAt       DateTime?
  aiSuggestions            Json? // { fieldName: { value, unit, confidence, reasoning } }
  specBlacklist            Json? // ["field1", "field2"] — don't suggest again
  createdAt                DateTime                  @default(now())
  createdBy                String?
  updatedAt                DateTime                  @updatedAt
  updatedBy                String?
  deletedAt                DateTime?
  deletedBy                String?
  budgetTier               BudgetTier?
  vendorId                 String?
  bookings                 BookingEquipment[]
  damageClaims             DamageClaim[]
  brand                    Brand?                    @relation(fields: [brandId], references: [id])
  category                 Category                  @relation(fields: [categoryId], references: [id])
  vendor                   Vendor?                   @relation(fields: [vendorId], references: [id])
  inspections              Inspection[]
  kitEquipment             KitEquipment[]
  maintenance              Maintenance[]
  media                    Media[]
  quoteEquipment           QuoteEquipment[]
  savedByUsers             SavedEquipment[]
  shootTypeRecommendations ShootTypeRecommendation[]
  product                  Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sku])
  @@index([slug])
  @@index([productId])
  @@index([categoryId])
  @@index([brandId])
  @@index([vendorId])
  @@index([condition])
  @@index([isActive])
  @@index([featured])
  @@index([deletedAt])
  @@index([budgetTier])
}

model ShootType {
  id              String                    @id @default(cuid())
  name            String
  slug            String                    @unique
  description     String?
  nameAr          String?
  nameZh          String?
  descriptionAr   String?
  descriptionZh   String?
  icon            String?
  coverImageUrl   String?
  sortOrder       Int                       @default(0)
  isActive        Boolean                   @default(true)
  questionnaire   Json?
  createdAt       DateTime                  @default(now())
  createdBy       String?
  updatedAt       DateTime                  @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  categoryFlows   ShootTypeCategoryFlow[]
  recommendations ShootTypeRecommendation[]

  @@index([slug])
  @@index([isActive])
  @@index([deletedAt])
}

model ShootTypeCategoryFlow {
  id                String    @id @default(cuid())
  shootTypeId       String
  categoryId        String
  sortOrder         Int       @default(0)
  isRequired        Boolean   @default(true)
  minRecommended    Int?
  maxRecommended    Int?
  stepTitle         String?
  stepTitleAr       String?
  stepDescription   String?
  stepDescriptionAr String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
