  priority                 String              @default("medium")
  scheduledDate            DateTime
  completedDate            DateTime?
  technicianId             String?
  description              String
  notes                    String?
  cost                     Decimal?            @db.Decimal(10, 2)
  partsUsed                Json?
  equipmentConditionBefore EquipmentCondition?
  equipmentConditionAfter  EquipmentCondition?
  createdAt                DateTime            @default(now())
  createdBy                String
  updatedAt                DateTime            @updatedAt
  updatedBy                String?
  deletedAt                DateTime?
  deletedBy                String?
  equipment                Equipment           @relation(fields: [equipmentId], references: [id])
  technician               User?               @relation("MaintenanceTechnician", fields: [technicianId], references: [id])

  @@index([maintenanceNumber])
  @@index([equipmentId])
  @@index([status])
  @@index([scheduledDate])
  @@index([technicianId])
  @@index([deletedAt])
}

model Invoice {
  id              String           @id @default(cuid())
  invoiceNumber   String           @unique
  customerId      String
  bookingId       String?
  type            InvoiceType      @default(BOOKING)
  status          InvoiceStatus    @default(DRAFT)
  issueDate       DateTime         @default(now())
  dueDate         DateTime
  paidDate        DateTime?
  subtotal        Decimal          @db.Decimal(10, 2)
  discount        Decimal?         @db.Decimal(10, 2)
  vatAmount       Decimal          @db.Decimal(10, 2)
  totalAmount     Decimal          @db.Decimal(10, 2)
  paidAmount      Decimal          @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal          @db.Decimal(10, 2)
  items           Json
  notes           String?
  paymentTerms    String?
  createdAt       DateTime         @default(now())
  createdBy       String
  updatedAt       DateTime         @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  booking         Booking?         @relation(fields: [bookingId], references: [id])
  customer        User             @relation(fields: [customerId], references: [id])
  payments        InvoicePayment[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([bookingId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

model InvoicePayment {
  id        String    @id @default(cuid())
  invoiceId String
  paymentId String
  amount    Decimal   @db.Decimal(10, 2)
  paidAt    DateTime  @default(now())
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment   Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, paymentId])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([deletedAt])
}

model Coupon {
  id                     String       @id @default(cuid())
  code                   String       @unique
  name                   String
  type                   CouponType
  discountValue          Decimal?     @db.Decimal(10, 2)
  discountPercentage     Decimal?     @db.Decimal(5, 2)
  minimumAmount          Decimal?     @db.Decimal(10, 2)
  maximumDiscount        Decimal?     @db.Decimal(10, 2)
  validFrom              DateTime
  validUntil             DateTime
  usageLimit             Int?
  usedCount              Int          @default(0)
  status                 CouponStatus @default(ACTIVE)
  applicableEquipmentIds Json?
  applicableStudioIds    Json?
  description            String?
  createdAt              DateTime     @default(now())
  createdBy              String
  updatedAt              DateTime     @updatedAt
  updatedBy              String?
  deletedAt              DateTime?
  deletedBy              String?

  @@index([code])
  @@index([status])
  @@index([validFrom, validUntil])
  @@index([deletedAt])
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  subject         String?
  content         String
  targetAudience  Json?
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int            @default(0)
  sentCount       Int            @default(0)
  openedCount     Int            @default(0)
  clickedCount    Int            @default(0)
  conversionCount Int            @default(0)
  createdAt       DateTime       @default(now())
  createdBy       String
  updatedAt       DateTime       @updatedAt
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  createdByUser   User           @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@index([type])
  @@index([scheduledAt])
  @@index([createdBy])
  @@index([deletedAt])
}

model Delivery {
  id             String         @id @default(cuid())
  deliveryNumber String         @unique
  bookingId      String
  type           DeliveryType
  status         DeliveryStatus @default(PENDING)
  scheduledDate  DateTime
  deliveredDate  DateTime?
  address        String
  city           String
  contactName    String
  contactPhone   String
  driverId       String?
  trackingNumber String?
  notes          String?
  createdAt      DateTime       @default(now())
  createdBy      String
  updatedAt      DateTime       @updatedAt
  updatedBy      String?
  deletedAt      DateTime?
  deletedBy      String?
  booking        Booking        @relation(fields: [bookingId], references: [id])
  driver         User?          @relation(fields: [driverId], references: [id])

  @@index([deliveryNumber])
  @@index([bookingId])
  @@index([status])
  @@index([scheduledDate])
  @@index([driverId])
  @@index([deletedAt])
}

model WebsiteContent {
  id          String             @id @default(cuid())
  key         String             @unique
  contentAr   String
  contentEn   String
  contentZh   String?
  type        WebsiteContentType @default(TEXT)
  section     String?
  isActive    Boolean            @default(true)
  version     Int                @default(1)
